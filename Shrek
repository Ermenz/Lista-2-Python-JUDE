A, B, C = map(int, input().split())

soma = A + B + C

if 0 <= A <= 80 and 0 <= B <= 80 and 0 <= C <= 80:
    # Usei o 'if' aqui
    if A > 50 or B > 50 or C > 50:
        print("Shrek vai dar o urro!")
    # E aqui troquei para 'elif' para conectar os blocos
    elif soma <= 100: 
        if soma > 80:
            print("Shrek vai dar o urro!")
        elif soma < 20:
            print("Shrek vai dar o urro!")
        else:
            print("Shrek ficou calmo.")
