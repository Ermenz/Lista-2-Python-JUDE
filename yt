import math

X = int(input())

cedulas_maquina = []
while len(cedulas_maquina) < X:
    cedulas_maquina.extend(map(int, input().split()))
cedulas_maquina = cedulas_maquina[:X]

Y = int(input())

faltam_reais = 4_000_000_000 - (Y * 6)
print(f"faltam: {faltam_reais}")

aceitaveis = [50, 100, 200]

if faltam_reais > 0:
    for nota in aceitaveis:
        if nota in cedulas_maquina:
            qtd_notas = math.ceil(faltam_reais / nota)
            print(f"notas de {nota}: {qtd_notas}")
